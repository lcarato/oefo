# OEFO Environment Variables
# Copy this file to .env and fill in your values

# Required: At least one LLM provider API key
ANTHROPIC_API_KEY=your-anthropic-key-here
# OPENAI_API_KEY=your-openai-key-here  # Optional fallback

# Optional: Anthropic organization ID
# ANTHROPIC_ORG_ID=your-org-id

# Optional: LLM provider and model settings
# OEFO_LLM_PROVIDER=anthropic
# OEFO_VISION_MODEL=claude-sonnet-4-20250514
# OEFO_QC_MODEL=claude-sonnet-4-20250514

# Optional: Data directories
# OEFO_DATA_DIR=./data
# OEFO_BASE_DIR=.

# Optional: Logging
# OEFO_LOG_LEVEL=INFO
# OEFO_DEBUG=false

# Optional: Processing
# OEFO_MAX_WORKERS=4
# OEFO_ENABLE_CACHING=true
# OEFO_ENABLE_PARALLEL_PROCESSING=true

# Optional: Ollama (local LLM fallback)
# OLLAMA_BASE_URL=http://localhost:11434
# OEFO_OLLAMA_MODEL=qwen3.5
